<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="SQLiteServerLogger" />
		<Option pch_mode="2" />
		<Option compiler="gcc" />
		<Build>
			<Target title="Debug Win32">
				<Option output="SQLiteServerLogger" prefix_auto="1" extension_auto="1" />
				<Option object_output="Debug Win32" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-DWIN32" />
					<Add option="-D_DEBUG" />
					<Add option="-D_CONSOLE" />
					<Add option="-W" />
					<Add option="-g" />
					<Add option="-O0" />
					<Add directory="$(SolutionDir)Source" />
					<Add directory="$(SolutionDir)DependentExtensions/DXTCompressor/Src" />
					<Add directory="$(SolutionDir)DependentExtensions/DXTCompressor/External/include" />
					<Add directory="$(SolutionDir)DependentExtensions/jpeg-7" />
					<Add directory="$(SolutionDir)DependentExtensions/SQLite3Plugin" />
					<Add directory="$(SolutionDir)DependentExtensions/SQLite3Plugin/Logger" />
					<Add directory="$(SolutionDir)DependentExtensions/SQLite3Plugin/Logger/ServerOnly" />
				</Compiler>
				<ResourceCompiler>
					<Add directory="$(SolutionDir)Source" />
					<Add directory="$(SolutionDir)DependentExtensions/DXTCompressor/Src" />
					<Add directory="$(SolutionDir)DependentExtensions/DXTCompressor/External/include" />
					<Add directory="$(SolutionDir)DependentExtensions/jpeg-7" />
					<Add directory="$(SolutionDir)DependentExtensions/SQLite3Plugin" />
					<Add directory="$(SolutionDir)DependentExtensions/SQLite3Plugin/Logger" />
					<Add directory="$(SolutionDir)DependentExtensions/SQLite3Plugin/Logger/ServerOnly" />
				</ResourceCompiler>
				<Linker>
					<Add library="$(SolutionDir)Lib/RakNet_VS2008_LibStatic_Debug_Win32" />
					<Add library="ws2_32" />
					<Add directory="$(SolutionDir)/DependentExtensions/DXTCompressor/External/lib" />
				</Linker>
				<ExtraCommands>
					<Add after="copy $(SolutionDir)DependentExtensions\DXTCompressor\*.dll .\" />
				</ExtraCommands>
			</Target>
			<Target title="Release Win32">
				<Option output="SQLiteServerLogger" prefix_auto="1" extension_auto="1" />
				<Option object_output="Release Win32" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-DWIN32" />
					<Add option="-DNDEBUG" />
					<Add option="-D_CONSOLE" />
					<Add option="-W" />
					<Add directory="$(SolutionDir)Source" />
