<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="Demo_BspCollision" />
		<Option pch_mode="2" />
		<Option compiler="gcc" />
		<Build>
			<Target title="Debug Win32">
				<Option output="Debug Win32/Demo_BspCollision" prefix_auto="1" extension_auto="1" />
				<Option object_output="Debug Win32" />
				<Option type="0" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-DWIN32" />
					<Add option="-D_DEBUG" />
					<Add option="-D_WINDOWS" />
					<Add option="-W" />
					<Add option="-g" />
					<Add option="-O0" />
					<Add directory="$(SolutionDir)DependentExtensions/SQLite3Plugin" />
					<Add directory="$(SolutionDir)Source" />
					<Add directory="$(SolutionDir)DependentExtensions/SQLite3Plugin/Logger" />
					<Add directory="$(SolutionDir)DependentExtensions/SQLite3Plugin/Logger/ClientOnly" />
					<Add directory="$(SolutionDir)DependentExtensions/SQLite3Plugin/Logger/ClientOnly/Optional" />
					<Add directory="$(OGRE_HOME)/samples/include" />
					<Add directory="$(OGRE_HOME)/include" />
					<Add directory="$(OGRE_HOME)/samples/refapp/include" />
				</Compiler>
				<ResourceCompiler>
					<Add directory="$(SolutionDir)DependentExtensions/SQLite3Plugin" />
					<Add directory="$(SolutionDir)Source" />
