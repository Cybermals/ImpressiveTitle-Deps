					<Add library="ReferenceAppLayer_d" />
					<Add library="ws2_32" />
					<Add directory="$(OGRE_HOME)/lib/" />
					<Add directory="../../../Dependencies/lib/Debug Win32" />
				</Linker>
				<ExtraCommands>
					<Add after="copy $(OGRE_HOME)\bin\Debug Win32\*.dll .\&#x0D;&#x0A;copy $(OGRE_HOME)\bin\Debug Win32\Plugins.cfg .\&#x0D;&#x0A;copy $(OGRE_HOME)\bin\Debug Win32\Media.cfg .\&#x0D;&#x0A;" />
				</ExtraCommands>
			</Target>
			<Target title="Release Win32">
