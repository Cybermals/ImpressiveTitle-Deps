<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="SQLiteClientLogger" />
		<Option pch_mode="2" />
		<Option compiler="gcc" />
		<Build>
			<Target title="Debug Win32">
				<Option output="SQLiteClientLogger" prefix_auto="1" extension_auto="1" />
				<Option object_output="Debug Win32" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-DWIN32" />
					<Add option="-D_DEBUG" />
					<Add option="-D_CONSOLE" />
					<Add option="-W" />
					<Add option="-g" />
					<Add option="-O0" />
					<Add directory="$(SolutionDir)DependentExtensions/SQLite3Plugin" />
					<Add directory="$(SolutionDir)Source" />
					<Add directory="$(SolutionDir)DependentExtensions/SQLite3Plugin/Logger" />
					<Add directory="$(SolutionDir)DependentExtensions/SQLite3Plugin/Logger/ClientOnly" />
				</Compiler>
				<ResourceCompiler>
					<Add directory="$(SolutionDir)DependentExtensions/SQLite3Plugin" />
					<Add directory="$(SolutionDir)Source" />
					<Add directory="$(SolutionDir)DependentExtensions/SQLite3Plugin/Logger" />
					<Add directory="$(SolutionDir)DependentExtensions/SQLite3Plugin/Logger/ClientOnly" />
				</ResourceCompiler>
				<Linker>
					<Add library="$(SolutionDir)Lib/RakNet_VS2008_LibStatic_Debug_Win32" />
					<Add library="ws2_32" />
				</Linker>
			</Target>
			<Target title="Release Win32">
				<Option output="SQLiteClientLogger" prefix_auto="1" extension_auto="1" />
				<Option object_output="Release Win32" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-DWIN32" />
					<Add option="-DNDEBUG" />
					<Add option="-D_CONSOLE" />
					<Add option="-W" />
					<Add directory="$(SolutionDir)DependentExtensions/SQLite3Plugin" />
					<Add directory="$(SolutionDir)Source" />
					<Add directory="$(SolutionDir)DependentExtensions/SQLite3Plugin/Logger" />
					<Add directory="$(SolutionDir)DependentExtensions/SQLite3Plugin/Logger/ClientOnly" />
				</Compiler>
				<ResourceCompiler>
					<Add directory="$(SolutionDir)DependentExtensions/SQLite3Plugin" />
					<Add directory="$(SolutionDir)Source" />
					<Add directory="$(SolutionDir)DependentExtensions/SQLite3Plugin/Logger" />
					<Add directory="$(SolutionDir)DependentExtensions/SQLite3Plugin/Logger/ClientOnly" />
				</ResourceCompiler>
				<Linker>
					<Add library="$(SolutionDir)Lib/RRakNet_VS2008_LibStatic_Debug_Win32" />
					<Add library="ws2_32" />
				</Linker>
			</Target>
		</Build>
		<Unit filename="../../../../SQLite3ClientPlugin.cpp" />
		<Unit filename="../../../../SQLite3ClientPlugin.h" />
		<Unit filename="../../../../SQLite3PluginCommon.cpp" />
		<Unit filename="../../../../SQLite3PluginCommon.h" />
		<Unit filename="../../../SQLiteLoggerCommon.cpp" />
		<Unit filename="../../../SQLiteLoggerCommon.h" />
		<Unit filename="../../Optional/SQLiteClientLogger_PacketLogger.cpp" />
		<Unit filename="../../Optional/SQLiteClientLogger_PacketLogger.h" />
		<Unit filename="../../Optional/SQLiteClientLogger_RNSLogger.cpp" />
		<Unit filename="../../Optional/SQLiteClientLogger_RNSLogger.h" />
		<Unit filename="../../SQLiteClientLoggerPlugin.cpp" />
		<Unit filename="../../SQLiteClientLoggerPlugin.h" />
		<Unit filename="SQLiteClientLoggerSample.cpp" />
		<Extensions>
			<code_completion />
			<envvars />
			<debugger />
		</Extensions>
	</Project>
</CodeBlocks_project_file>
