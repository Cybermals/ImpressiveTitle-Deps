<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="SQLite3Plugin" />
		<Option pch_mode="2" />
		<Option compiler="gcc" />
		<Build>
			<Target title="Debug Win32">
				<Option output="SQLite3Plugin" prefix_auto="1" extension_auto="1" />
				<Option object_output="Debug Win32" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-DWIN32" />
					<Add option="-D_DEBUG" />
					<Add option="-D_CONSOLE" />
					<Add option="-W" />
					<Add option="-g" />
					<Add option="-O0" />
					<Add directory="../../Source" />
					<Add directory="./ServerOnly" />
					<Add directory="./" />
					<Add directory="./ClientOnly" />
				</Compiler>
				<ResourceCompiler>
					<Add directory="../../Source" />
					<Add directory="./ServerOnly" />
					<Add directory="./" />
					<Add directory="./ClientOnly" />
				</ResourceCompiler>
				<Linker>
					<Add library="./../../Lib/RakNet_VS2008_LibStatic_Debug_Win32" />
					<Add library="ws2_32" />
				</Linker>
			</Target>
			<Target title="Release Win32">
				<Option output="SQLite3Plugin" prefix_auto="1" extension_auto="1" />
				<Option object_output="Release Win32" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-DWIN32" />
					<Add option="-DNDEBUG" />
					<Add option="-D_CONSOLE" />
					<Add option="-W" />
					<Add directory="../../Source" />
					<Add directory="./ServerOnly" />
					<Add directory="./" />
					<Add directory="./ClientOnly" />
				</Compiler>
				<ResourceCompiler>
					<Add directory="../../Source" />
					<Add directory="./ServerOnly" />
					<Add directory="./" />
					<Add directory="./ClientOnly" />
				</ResourceCompiler>
				<Linker>
					<Add library="./../../Lib/RakNet_VS2008_LibStatic_Release_Win32" />
					<Add library="ws2_32" />
				</Linker>
			</Target>
		</Build>
		<Unit filename="SQLite3ClientPlugin.cpp" />
		<Unit filename="SQLite3ClientPlugin.h" />
		<Unit filename="SQLite3PluginCommon.cpp" />
		<Unit filename="SQLite3PluginCommon.h" />
		<Unit filename="SQLite3Sample.cpp" />
		<Unit filename="SQLite3ServerPlugin.cpp" />
		<Unit filename="SQLite3ServerPlugin.h" />
		<Unit filename="sqlite3.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="sqlite3.h" />
		<Unit filename="sqlite3ext.h" />
		<Extensions>
			<code_completion />
			<envvars />
			<debugger />
		</Extensions>
	</Project>
</CodeBlocks_project_file>
