<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="CloudTest" />
		<Option pch_mode="2" />
		<Option compiler="gcc" />
		<Build>
			<Target title="Debug Win32">
				<Option output="Debug/CloudTest" prefix_auto="1" extension_auto="1" />
				<Option object_output="Debug" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-DWIN32" />
					<Add option="-D_DEBUG" />
					<Add option="-D_CONSOLE" />
					<Add option="-W" />
					<Add option="-g" />
					<Add option="-O0" />
					<Add directory="./../../Source" />
				</Compiler>
				<ResourceCompiler>
					<Add directory="./../../Source" />
				</ResourceCompiler>
				<Linker>
					<Add library="./../../Lib/RakNet_VS2008_LibStatic_Debug_Win32" />
					<Add library="ws2_32" />
				</Linker>
			</Target>
			<Target title="Release Win32">
				<Option output="Release/CloudTest" prefix_auto="1" extension_auto="1" />
				<Option object_output="Release" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-DWIN32" />
					<Add option="-DNDEBUG" />
					<Add option="-D_CONSOLE" />
					<Add option="-W" />
					<Add directory="./../../Source" />
				</Compiler>
				<ResourceCompiler>
					<Add directory="./../../Source" />
				</ResourceCompiler>
				<Linker>
					<Add library="./../../Lib/RakNet_VS2008_LibStatic_Release_Win32" />
					<Add library="ws2_32" />
				</Linker>
			</Target>
		</Build>
		<Unit filename="CloudTest.cpp" />
		<Extensions>
			<code_completion />
			<envvars />
			<debugger />
		</Extensions>
	</Project>
</CodeBlocks_project_file>
