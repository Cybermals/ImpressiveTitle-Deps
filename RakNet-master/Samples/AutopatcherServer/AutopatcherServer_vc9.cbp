					<Add library="C:/Program" />
					<Add library="Files" />
					<Add library="(x86)/PostgreSQL/9.2/lib/libpq" />
				</Linker>
				<ExtraCommands>
					<Add after="copy C:\Program Files (x86)\PostgreSQL\9.2\bin\*.dll .\Release" />
				</ExtraCommands>
			</Target>
		</Build>
