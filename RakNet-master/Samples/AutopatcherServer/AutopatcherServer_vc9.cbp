<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="AutopatcherServer_PostgreSQL" />
		<Option pch_mode="2" />
		<Option compiler="gcc" />
		<Build>
			<Target title="Debug Win32">
				<Option output="Debug Win32/AutopatcherServer" prefix_auto="1" extension_auto="1" />
				<Option object_output="Debug Win32" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-D_CRT_SECURE_NO_DEPRECATE" />
					<Add option="-DWIN32" />
					<Add option="-D_DEBUG" />
					<Add option="-D_CONSOLE" />
					<Add option="-W" />
					<Add option="-g" />
					<Add option="-O0" />
					<Add directory="./" />
					<Add directory="./../../Source" />
					<Add directory="./../../DependentExtensions/Autopatcher" />
					<Add directory="./../../DependentExtensions/bzip2-1.0.6" />
					<Add directory="./../../DependentExtensions/Autopatcher/AutopatcherPostgreRepository" />
					<Add directory="./../../DependentExtensions/PostgreSQLInterface" />
					<Add directory="./../../DependentExtensions/openssl-1.0.0d/include" />
				</Compiler>
				<ResourceCompiler>
					<Add directory="./" />
					<Add directory="./../../Source" />
					<Add directory="./../../DependentExtensions/Autopatcher" />
					<Add directory="./../../DependentExtensions/bzip2-1.0.6" />
					<Add directory="./../../DependentExtensions/Autopatcher/AutopatcherPostgreRepository" />
					<Add directory="./../../DependentExtensions/PostgreSQLInterface" />
					<Add directory="./../../DependentExtensions/openssl-1.0.0d/include" />
				</ResourceCompiler>
				<Linker>
					<Add library="./../../Lib/RakNet_VS2008_LibStatic_Debug_Win32" />
					<Add library="ws2_32" />
					<Add library="./../../DependentExtensions/Autopatcher/AutopatcherPostgreRepository/Debug/AutopatcherPostgreRepository" />
					<Add library="C:/Program" />
					<Add library="Files" />
					<Add library="(x86)/PostgreSQL/9.2/lib/libpq" />
				</Linker>
				<ExtraCommands>
					<Add after="copy C:\Program Files (x86)\PostgreSQL\9.2\bin\*.dll .\Debug" />
				</ExtraCommands>
			</Target>
			<Target title="Release Win32">
				<Option output="Release Win32/AutopatcherServer" prefix_auto="1" extension_auto="1" />
				<Option object_output="Release Win32" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-D_CRT_SECURE_NO_DEPRECATE" />
					<Add option="-DWIN32" />
					<Add option="-DNDEBUG" />
					<Add option="-D_CONSOLE" />
					<Add option="-W" />
					<Add directory="./" />
					<Add directory="./../../Source" />
					<Add directory="./../../DependentExtensions/Autopatcher" />
					<Add directory="./../../DependentExtensions/bzip2-1.0.6" />
					<Add directory="./../../DependentExtensions/Autopatcher/AutopatcherPostgreRepository" />
					<Add directory="./../../DependentExtensions/PostgreSQLInterface" />
					<Add directory="./../../DependentExtensions/openssl-1.0.0d/include" />
				</Compiler>
				<ResourceCompiler>
					<Add directory="./" />
					<Add directory="./../../Source" />
					<Add directory="./../../DependentExtensions/Autopatcher" />
					<Add directory="./../../DependentExtensions/bzip2-1.0.6" />
					<Add directory="./../../DependentExtensions/Autopatcher/AutopatcherPostgreRepository" />
					<Add directory="./../../DependentExtensions/PostgreSQLInterface" />
					<Add directory="./../../DependentExtensions/openssl-1.0.0d/include" />
				</ResourceCompiler>
				<Linker>
					<Add library="./../../Lib/RakNet_VS2008_LibStatic_Release_Win32" />
					<Add library="ws2_32" />
