					<Add library="ws2_32" />
					<Add library="fmodex_vc" />
					<Add directory="C:/Program Files (x86)/FMOD SoundSystem/FMOD Programmers API Windows/api/lib" />
				</Linker>
				<ExtraCommands>
					<Add after="copy C:\Program Files (x86)\FMOD SoundSystem\FMOD Programmers API Windows\api\fmodex.dll .\Debug" />
				</ExtraCommands>
			</Target>
