		<Build>
			<Target title="Debug Win32">
				<Option output="Debug Win32/RakVoice" prefix_auto="1" extension_auto="1" />
				<Option object_output="Debug Win32" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-D_CRT_SECURE_NO_DEPRECATE" />
					<Add option="-DWIN32" />
					<Add option="-D_DEBUG" />
					<Add option="-D_CONSOLE" />
					<Add option="-DHAVE_CONFIG_H" />
					<Add option="-W" />
					<Add option="-g" />
					<Add option="-O0" />
					<Add directory="./../../Source" />
