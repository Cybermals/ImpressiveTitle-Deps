<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="RoomsPlugin" />
		<Option pch_mode="2" />
		<Option compiler="gcc" />
		<Build>
			<Target title="Debug Win32">
				<Option output="Rooms" prefix_auto="1" extension_auto="1" />
				<Option object_output="Debug Win32" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-DWIN32" />
					<Add option="-D_DEBUG" />
					<Add option="-D_CONSOLE" />
					<Add option="-D_CRT_NONSTDC_NO_DEPRECATE" />
					<Add option="-D_CRT_SECURE_NO_DEPRECATE" />
					<Add option="-Wall" />
					<Add option="-g" />
					<Add option="-O0" />
					<Add directory="./../../Source" />
					<Add directory="./../../DependentExtensions/Lobby2/Rooms" />
				</Compiler>
				<ResourceCompiler>
					<Add directory="./../../Source" />
					<Add directory="./../../DependentExtensions/Lobby2/Rooms" />
				</ResourceCompiler>
				<Linker>
					<Add library="./../../Lib/RakNet_VS2008_LibStatic_Debug_Win32" />
					<Add library="ws2_32" />
				</Linker>
			</Target>
			<Target title="Release Win32">
				<Option output="Rooms" prefix_auto="1" extension_auto="1" />
				<Option object_output="Release Win32" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-DWIN32" />
					<Add option="-DNDEBUG" />
					<Add option="-D_CONSOLE" />
					<Add option="-D_CRT_NONSTDC_NO_DEPRECATE" />
					<Add option="-D_CRT_SECURE_NO_DEPRECATE" />
					<Add option="-W" />
					<Add directory="./../../Source" />
					<Add directory="./../../DependentExtensions/Lobby2/Rooms" />
				</Compiler>
				<ResourceCompiler>
					<Add directory="./../../Source" />
					<Add directory="./../../DependentExtensions/Lobby2/Rooms" />
				</ResourceCompiler>
				<Linker>
					<Add library="./../../Lib/RakNet_VS2008_LibStatic_Release_Win32" />
					<Add library="ws2_32" />
				</Linker>
			</Target>
		</Build>
		<Unit filename="../../DependentExtensions/Lobby2/Rooms/IntervalTimer.cpp" />
		<Unit filename="../../DependentExtensions/Lobby2/Rooms/IntervalTimer.h" />
		<Unit filename="../../DependentExtensions/Lobby2/Rooms/ProfanityFilter.cpp" />
		<Unit filename="../../DependentExtensions/Lobby2/Rooms/ProfanityFilter.h" />
		<Unit filename="../../DependentExtensions/Lobby2/Rooms/RoomTypes.cpp" />
		<Unit filename="../../DependentExtensions/Lobby2/Rooms/RoomTypes.h" />
		<Unit filename="../../DependentExtensions/Lobby2/Rooms/RoomsContainer.cpp" />
		<Unit filename="../../DependentExtensions/Lobby2/Rooms/RoomsContainer.h" />
		<Unit filename="../../DependentExtensions/Lobby2/Rooms/RoomsErrorCodes.cpp" />
		<Unit filename="../../DependentExtensions/Lobby2/Rooms/RoomsErrorCodes.h" />
		<Unit filename="../../DependentExtensions/Lobby2/Rooms/RoomsPlugin.cpp" />
		<Unit filename="../../DependentExtensions/Lobby2/Rooms/RoomsPlugin.h" />
		<Unit filename="RoomsSample.cpp" />
		<Unit filename="readme.txt" />
		<Extensions>
			<code_completion />
			<envvars />
			<debugger />
		</Extensions>
	</Project>
</CodeBlocks_project_file>
