<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="SteamLobby" />
		<Option pch_mode="2" />
		<Option compiler="gcc" />
		<Build>
			<Target title="Debug Win32">
				<Option output="SteamLobby" prefix_auto="1" extension_auto="1" />
				<Option object_output="Debug Win32" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-DWIN32" />
					<Add option="-D_DEBUG" />
					<Add option="-D_CONSOLE" />
					<Add option="-D_CRT_NONSTDC_NO_DEPRECATE" />
					<Add option="-D_CRT_SECURE_NO_DEPRECATE" />
					<Add option="-DMAXIMUM_MTU_SIZE=1200" />
					<Add option="-Wall" />
					<Add option="-g" />
					<Add option="-O0" />
					<Add directory="./../../Source" />
					<Add directory="./../../DependentExtensions/Lobby2/Steam" />
					<Add directory="./../../DependentExtensions/Lobby2" />
					<Add directory="C:/Steamworks/public/steam" />
				</Compiler>
				<ResourceCompiler>
					<Add directory="./../../Source" />
					<Add directory="./../../DependentExtensions/Lobby2/Steam" />
					<Add directory="./../../DependentExtensions/Lobby2" />
					<Add directory="C:/Steamworks/public/steam" />
				</ResourceCompiler>
				<Linker>
					<Add library="./../../Lib/RakNet_VS2008_LibStatic_Debug_Win32" />
					<Add library="ws2_32" />
					<Add library="steam_api" />
					<Add directory="C:/Steamworks/redistributable_bin" />
				</Linker>
				<ExtraCommands>
					<Add after="copy C:\Steamworks\redistributable_bin\*.dll $(SolutionDir)Debug Win32&#x0D;&#x0A;copy C:\Steamworks\SteamworksExample\steam_appid.txt  C:\Users\Eric\Documents\Libraries\RakNet-master\Samples\SteamLobby\&#x0D;&#x0A;" />
				</ExtraCommands>
			</Target>
			<Target title="Release Win32">
				<Option output="SteamLobby" prefix_auto="1" extension_auto="1" />
				<Option object_output="Release Win32" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-DWIN32" />
					<Add option="-DNDEBUG" />
					<Add option="-D_CONSOLE" />
					<Add option="-D_CRT_NONSTDC_NO_DEPRECATE" />
					<Add option="-D_CRT_SECURE_NO_DEPRECATE" />
					<Add option="-DMAXIMUM_MTU_SIZE=1200" />
					<Add option="-W" />
					<Add directory="./../../Source" />
					<Add directory="./../../DependentExtensions/Lobby2/Steam" />
					<Add directory="./../../DependentExtensions/Lobby2" />
					<Add directory="C:/Steamworks/public/steam" />
				</Compiler>
				<ResourceCompiler>
					<Add directory="./../../Source" />
					<Add directory="./../../DependentExtensions/Lobby2/Steam" />
					<Add directory="./../../DependentExtensions/Lobby2" />
					<Add directory="C:/Steamworks/public/steam" />
				</ResourceCompiler>
				<Linker>
					<Add library="./../../Lib/RakNet_VS2008_LibStatic_Release_Win32" />
					<Add library="ws2_32" />
					<Add library="steam_api" />
					<Add directory="C:/Steamworks/redistributable_bin" />
				</Linker>
				<ExtraCommands>
					<Add after="copy C:\Steamworks\redistributable_bin\*.dll $(SolutionDir)Release Win32&#x0D;&#x0A;copy C:\Steamworks\SteamworksExample\steam_appid.txt  C:\Users\Eric\Documents\Libraries\RakNet-master\Samples\SteamLobby\&#x0D;&#x0A;" />
				</ExtraCommands>
			</Target>
		</Build>
		<Unit filename="../../DependentExtensions/Lobby2/Lobby2Message.cpp" />
