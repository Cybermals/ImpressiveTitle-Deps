<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="AutopatcherServer_MySQL" />
		<Option pch_mode="2" />
		<Option compiler="gcc" />
		<Build>
			<Target title="Debug Win32">
				<Option output="Debug/AutopatcherServer" prefix_auto="1" extension_auto="1" />
				<Option object_output="Debug" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-D_CRT_NONSTDC_NO_DEPRECATE" />
					<Add option="-D_CRT_SECURE_NO_DEPRECATE" />
					<Add option="-DWIN32" />
					<Add option="-D_DEBUG" />
					<Add option="-D_CONSOLE" />
					<Add option="-D__WIN__" />
					<Add option="-W" />
					<Add option="-g" />
					<Add option="-O0" />
					<Add directory="./" />
					<Add directory="./../../Source" />
					<Add directory="./../../DependentExtensions/Autopatcher" />
					<Add directory="./../../DependentExtensions/bzip2-1.0.6" />
					<Add directory="./../../DependentExtensions/Autopatcher/AutopatcherMySQLRepository" />
					<Add directory="./../../DependentExtensions/MySQLInterface" />
				</Compiler>
				<ResourceCompiler>
					<Add directory="./" />
					<Add directory="./../../Source" />
					<Add directory="./../../DependentExtensions/Autopatcher" />
					<Add directory="./../../DependentExtensions/bzip2-1.0.6" />
					<Add directory="./../../DependentExtensions/Autopatcher/AutopatcherMySQLRepository" />
					<Add directory="./../../DependentExtensions/MySQLInterface" />
				</ResourceCompiler>
				<Linker>
					<Add library="./../../Lib/RakNet_VS2008_LibStatic_Debug_Win32" />
					<Add library="ws2_32" />
					<Add library="./../../DependentExtensions/Autopatcher/AutopatcherMySQLRepository/Debug/AutopatcherMySQLRepository" />
					<Add library="C:/Program" />
					<Add library="Files" />
					<Add library="(x86)/MySQL/MySQL" />
					<Add library="Server" />
					<Add library="5.1/lib/opt/libmysql" />
				</Linker>
				<ExtraCommands>
					<Add after="copy C:\Program Files (x86)\MySQL\MySQL Server 5.1\bin\*.dll .\Debug" />
				</ExtraCommands>
			</Target>
			<Target title="Release Win32">
				<Option output="Release/AutopatcherServer" prefix_auto="1" extension_auto="1" />
				<Option object_output="Release" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-D_CRT_NONSTDC_NO_DEPRECATE" />
					<Add option="-D_CRT_SECURE_NO_DEPRECATE" />
					<Add option="-DWIN32" />
					<Add option="-DNDEBUG" />
					<Add option="-D_CONSOLE" />
					<Add option="-D__WIN__" />
					<Add option="-W" />
					<Add directory="./" />
					<Add directory="./../../Source" />
					<Add directory="./../../DependentExtensions/Autopatcher" />
					<Add directory="./../../DependentExtensions/bzip2-1.0.6" />
					<Add directory="./../../DependentExtensions/Autopatcher/AutopatcherMySQLRepository" />
					<Add directory="./../../DependentExtensions/MySQLInterface" />
				</Compiler>
				<ResourceCompiler>
					<Add directory="./" />
					<Add directory="./../../Source" />
					<Add directory="./../../DependentExtensions/Autopatcher" />
					<Add directory="./../../DependentExtensions/bzip2-1.0.6" />
					<Add directory="./../../DependentExtensions/Autopatcher/AutopatcherMySQLRepository" />
					<Add directory="./../../DependentExtensions/MySQLInterface" />
				</ResourceCompiler>
				<Linker>
					<Add library="./../../Lib/RakNet_VS2008_LibStatic_Release_Win32" />
					<Add library="ws2_32" />
					<Add library="./../../DependentExtensions/Autopatcher/AutopatcherMySQLRepository/Release/AutopatcherMySQLRepository" />
					<Add library="C:/Program" />
					<Add library="Files" />
					<Add library="(x86)/MySQL/MySQL" />
					<Add library="Server" />
					<Add library="5.1/lib/opt/libmysql" />
				</Linker>
				<ExtraCommands>
					<Add after="copy C:\Program Files (x86)\MySQL\MySQL Server 5.1\bin\*.dll .\Release" />
				</ExtraCommands>
			</Target>
		</Build>
		<Unit filename="../../DependentExtensions/Autopatcher/AutopatcherServer.cpp" />
		<Unit filename="../../DependentExtensions/Autopatcher/AutopatcherServer.h" />
		<Unit filename="../../DependentExtensions/Autopatcher/CreatePatch.cpp" />
