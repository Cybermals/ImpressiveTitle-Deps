<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="NATCompleteClient" />
		<Option pch_mode="2" />
		<Option compiler="gcc" />
		<Build>
			<Target title="Debug Win32">
				<Option output="NATCompleteClient" prefix_auto="1" extension_auto="1" />
				<Option object_output="Debug Win32" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-D_CRT_SECURE_NO_DEPRECATE" />
					<Add option="-DWIN32" />
					<Add option="-D_DEBUG" />
					<Add option="-D_CONSOLE" />
					<Add option="-DSTATICLIB" />
					<Add option="-W" />
					<Add option="-g" />
					<Add option="-O0" />
					<Add directory="./../../Source" />
					<Add directory="$(SolutionDir)DependentExtensions/miniupnpc-1.6.20120410" />
				</Compiler>
				<ResourceCompiler>
					<Add directory="./../../Source" />
					<Add directory="$(SolutionDir)DependentExtensions/miniupnpc-1.6.20120410" />
				</ResourceCompiler>
				<Linker>
					<Add library="./../../Lib/RakNet_VS2008_LibStatic_Debug_Win32" />
					<Add library="./../../Lib/RakNet_VS2008_MiniupnpcStatic_Debug_Win32" />
					<Add library="ws2_32" />
					<Add library="IPHlpApi" />
				</Linker>
			</Target>
			<Target title="Release Win32">
				<Option output="NATCompleteClient" prefix_auto="1" extension_auto="1" />
				<Option object_output="Release Win32" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-D_CRT_SECURE_NO_DEPRECATE" />
					<Add option="-DWIN32" />
					<Add option="-DNDEBUG" />
					<Add option="-D_CONSOLE" />
					<Add option="-DSTATICLIB" />
					<Add option="-W" />
					<Add directory="./../../Source" />
					<Add directory="$(SolutionDir)DependentExtensions/miniupnpc-1.6.20120410" />
				</Compiler>
				<ResourceCompiler>
					<Add directory="./../../Source" />
					<Add directory="$(SolutionDir)DependentExtensions/miniupnpc-1.6.20120410" />
				</ResourceCompiler>
				<Linker>
					<Add library="./../../Lib/RakNet_VS2008_LibStatic_Release_Win32" />
					<Add library="./../../Lib/RakNet_VS2008_MiniupnpcStatic_Release_Win32" />
					<Add library="ws2_32" />
					<Add library="IPHlpApi" />
				</Linker>
			</Target>
		</Build>
		<Unit filename="main.cpp" />
		<Unit filename="readme.txt" />
		<Extensions>
			<code_completion />
			<envvars />
			<debugger />
		</Extensions>
	</Project>
</CodeBlocks_project_file>
