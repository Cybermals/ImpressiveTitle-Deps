<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="TestDLL" />
		<Option pch_mode="2" />
		<Option compiler="gcc" />
		<Build>
			<Target title="Debug Win32">
				<Option output="Debug Win32/TestDLL" prefix_auto="1" extension_auto="1" />
				<Option object_output="Debug Win32" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-D_CRT_SECURE_NO_DEPRECATE" />
					<Add option="-DWIN32" />
					<Add option="-D_DEBUG" />
					<Add option="-D_CONSOLE" />
					<Add option="-W" />
					<Add option="-g" />
					<Add option="-O0" />
					<Add directory="D:/RakNet4/DependentExtensions/XML" />
					<Add directory="./../../Source" />
				</Compiler>
				<ResourceCompiler>
					<Add directory="D:/RakNet4/DependentExtensions/XML" />
					<Add directory="./../../Source" />
				</ResourceCompiler>
				<ExtraCommands>
					<Add after="copy $(SolutionDir)Lib\RakNet_DLL_Debug Win32_Win32.dll" />
				</ExtraCommands>
			</Target>
			<Target title="Release Win32">
				<Option output="Release Win32/TestDLL" prefix_auto="1" extension_auto="1" />
				<Option object_output="Release Win32" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-D_CRT_SECURE_NO_DEPRECATE" />
					<Add option="-DWIN32" />
					<Add option="-DNDEBUG" />
					<Add option="-D_CONSOLE" />
					<Add option="-W" />
					<Add directory="./../../Source" />
				</Compiler>
				<ResourceCompiler>
					<Add directory="./../../Source" />
				</ResourceCompiler>
				<ExtraCommands>
					<Add after="copy $(SolutionDir)Lib\RakNet_DLL_Release Win32_Win32.dll" />
				</ExtraCommands>
			</Target>
		</Build>
		<Unit filename="../../DependentExtensions/XML/xmlParser.cpp" />
		<Unit filename="../../DependentExtensions/XML/xmlParser.h" />
		<Unit filename="../../Source/RakMemoryOverride.cpp" />
		<Unit filename="../../Source/RakMemoryOverride.h" />
		<Unit filename="main.cpp" />
		<Unit filename="readme.txt" />
		<Extensions>
			<code_completion />
			<envvars />
			<debugger />
		</Extensions>
	</Project>
</CodeBlocks_project_file>
